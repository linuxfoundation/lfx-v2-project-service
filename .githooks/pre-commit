#
# Pre-commit hook: format, lint, and license-check staged Go files.
# Installed automatically by `make deps` via `git config core.hooksPath .githooks`.

set -e

# Format any staged .go files and re-stage them.
# Use non-NUL listing to check for staged files (shell vars can't hold NUL bytes),
# then pipe the NUL-delimited listing directly into xargs -0 for safe processing.
if git diff --cached --name-only --diff-filter=ACM -- '*.go' | grep -q .; then
  git diff --cached --name-only -z --diff-filter=ACM -- '*.go' | xargs -0 gofmt -w
  git diff --cached --name-only -z --diff-filter=ACM -- '*.go' | xargs -0 git add -f
fi

# Run go vet over the whole module (catches syntax errors and obvious bugs).
go vet ./...

# Run golangci-lint if available.
if command -v golangci-lint >/dev/null 2>&1; then
  golangci-lint run ./...
fi

# Check license headers on all staged source files.
make license-check
